# Jamendo API Keys (Prefix with EXPO_PUBLIC_ for client-side access in Expo)
EXPO_PUBLIC_JAMENDO_CLIENT_ID=your_jamendo_client_id_here
EXPO_PUBLIC_JAMENDO_BASE_URL=https://api.jamendo.com/v3.0

# Server URL for the mobile app
EXPO_PUBLIC_API_BASE_URL=https://your-server-url.com/api

# Server-side Secrets (Used by the backend)
YOUTUBE_API_KEY=your_youtube_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
PORT=3000
